<?xml version="1.1" encoding="UTF-8" ?>
<Grid column_spacing="6" row_spacing="6" margin_top="6" margin_start="6" margin_end="6" margin_bottom="6">
    <Row>
        <Label xalign="0">Идентификатор</Label>
        <Label id="id_value" xalign="0">{{ entity.id }}</Label>
	</Row>
    <Row>
        <Label xalign="0">Название</Label>
        <Entry id="title_entry" colspan="2">{{ entity.title }}</Entry>
	</Row>
    <Row>
        <Label xalign="0">Описание:</Label>
	</Row>
    <Row>
        <TextView id="description_entry" colspan="3">{{ entity.description }}</TextView>
    </Row>
	<Row>
	    <EntityColumnView item_type="Human" id="humans_column_view" colspan="3" linking_table="LinkHumanMeeting" item_main="meeting" item_slave="human"></EntityColumnView>    
	</Row>
</Grid>