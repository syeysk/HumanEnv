<?xml version="1.1" encoding="UTF-8" ?>
<Grid id="grid">
    <Row>
        <Label>Идентификатор</Label>
        <Label id="id_value">{{ entity.id }}</Label>
	</Row>
    <Row>
        <Label>Название</Label>
        <Entry id="title_entry" colspan="2">{{ entity.title }}</Entry>
	</Row>
    <Row>
        <Label>Цель задачи в отношениях</Label>
        <UniDropDown id="aim_entry"></UniDropDown>
        <Button id="aim_edit_button">Edit</Button>
	</Row>
	<Row>
	    <EntityColumnView item_type="Human" id="humans_column_view" colspan="3" linking_table="LinkTaskHuman" item_main="task" item_slave="human"></EntityColumnView>    
	</Row>
</Grid>