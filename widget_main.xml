<interface>
    <template class="example1" parent="GtkApplicationWindow">
        <child>
            <object class="GtkBox" id="main_box">
                <property name="orientation">vertical</property>
                <child>
                    <object class="GtkBox" id="top_box">
                        <property name="orientation">horizontal</property>
                        <child>
                            <object class="GtkBox" id="top_left_box">
                                <property name="orientation">vertical</property>
                                <child>
                                    <object class="GtkLabel" id="birthdate_label">
                                        <property name="label">Birth date</property>
                                    </object>
                                </child>
                            </object>
                        </child>
                        <child>
                            <object class="GtkBox" id="top_right_box">
                                <property name="orientation">vertical</property>
                            </object>
                        </child>
                    </object>
                </child>
                <child>
                    <object class="GtkBox" id="bottom_box">
                        <property name="orientation">vertical</property>
                        <child>
                            <object class="GtkLabel" id="links_label">
                                <property name="label">Links</property>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </child>
        <!--</child>
            <object class="GtkButton" id="hello_button">
                <property name="label">Hello World</property>
                <signal name="clicked" handler="hello_button_clicked" swapped="no" />
            </object>
        </child>-->
    </template>
</interface>