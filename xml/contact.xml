<?xml version="1.1" encoding="UTF-8" ?>
<Grid column_spacing="6" row_spacing="6" margin_top="6" margin_start="6" margin_end="6" margin_bottom="6">
    <Row>
        <Label xalign="0">Идентификатор</Label>
        <Label id="id_value" xalign="0">{{ entity.id }}</Label>
	</Row>
    <Row>
        <Label xalign="0">Значение</Label>
        <Entry id="value_entry" colspan="2">{{ entity.value }}</Entry>
	</Row>
    <Row>
        <Label xalign="0">Тип</Label>
        <UniDropDown id="type_entry"></UniDropDown>
        <Button id="type_edit_button">Edit</Button>
	</Row>
    <Row>
        <Label xalign="0">Статус</Label>
        <UniDropDown id="status_entry" colspan="2"></UniDropDown>
	</Row>
	<Row>
	    <Box id="adapter_area" spacing="6" orientation="HORIZONTAL" colspan="3">
		</Box>
	</Row>
	<Row>
	    <EntityColumnView item_type="Human" id="humans_column_view" colspan="3" linking_table="LinkContactHuman" item_main="contact" item_slave="human"></EntityColumnView>    
	</Row>
	<Row>
	    <EntityColumnView item_type="Community" id="communities_column_view" colspan="3" linking_table="LinkContactCommunity" item_main="contact" item_slave="community"></EntityColumnView>    
	</Row>
</Grid>