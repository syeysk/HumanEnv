<?xml version="1.1" encoding="UTF-8" ?>
<Grid column_spacing="6" row_spacing="6" margin_top="6" margin_start="6" margin_end="6" margin_bottom="6">
    <Row>
        <Label xalign="0">Идентификатор</Label>
        <Label id="id_value" xalign="0">{{ entity.id }}</Label>
	</Row>
    <Row>
        <Label xalign="0">Название</Label>
        <Entry id="title_entry" colspan="2">{{ entity.title }}</Entry>
	</Row>
    <Row>
        <Label xalign="0">Цель задачи в отношениях</Label>
        <UniDropDown id="aim_entry"></UniDropDown>
        <Button id="aim_edit_button">Edit</Button>
	</Row>
    <Row>
        <CheckButton colspan="3" id="has_done">Выполнено</CheckButton>
	</Row>
	<Row>
	    <EntityColumnView item_type="Human" id="humans_column_view" colspan="3" linking_table="LinkTaskHuman" item_main="task" item_slave="human"></EntityColumnView>
	</Row>
    <Row>
      <EntityColumnView item_type="Community" id="communities_column_view" colspan="3" linking_table="LinkTaskCommunity" item_main="task" item_slave="community"></EntityColumnView>    
	</Row>
</Grid>